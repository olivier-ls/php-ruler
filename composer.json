{
    "name": "ols/php-ruler",
    "description": "A transparent expression & rule evaluator in pure PHP. No dependencies. Strict typing, a safe mode that collects missing variables instead of failing, and an explain mode that shows exactly why a rule passed or failed. Move business logic out of your code.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "expression",
        "expression language",
        "rule engine",
        "rules",
        "evaluator",
        "business rules",
        "predicate",
        "strict",
        "explain",
        "no dependencies"
    ],
    "authors": [
        {
            "name": "Olivier",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ols\\PhpRuler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ols\\PhpRuler\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
